---
import Layout from '../layouts/Layout.astro';

// Get parameters from URL
const url = new URL(Astro.request.url);
const template = url.searchParams.get('template');
const duration = url.searchParams.get('duration');
const aspectRatio = url.searchParams.get('aspectRatio');
const script = url.searchParams.get('script');

// Template to art style mapping
const templateToArtStyle = {
  'general': 'realistic',
  'educational': 'minimal',
  'entertainment': 'vibrant',
  'business': 'professional',
  'social': 'modern'
};

console.log('Voice selection page loaded with:', { template, duration, aspectRatio, script });

// Redirect if any parameter is missing
if (!template || !duration || !aspectRatio || !script) {
  return Astro.redirect('/create?error=missing-parameters');
}
---

<Layout title="Select Voice - ViroShort">
  <div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900">
    <!-- Header -->
    <div class="border-b border-white/10 bg-black/20 backdrop-blur-sm">
      <div class="container mx-auto px-4 py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-white">Voice Selection</h1>
            <div class="flex items-center mt-2 text-sm text-gray-300">
              <span class="bg-purple-600 text-white px-2 py-1 rounded-full text-xs font-medium">Step 2</span>
              <span class="ml-2">Choose your perfect voice</span>
            </div>
          </div>
          <a href="/create" class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      <!-- Script Preview Card -->
      <div class="bg-white/5 backdrop-blur-sm rounded-xl border border-white/10 p-6 mb-8">
        <h2 class="text-lg font-semibold text-white mb-3">Script Preview</h2>
        <div class="bg-black/20 rounded-lg p-4 max-h-32 overflow-y-auto">
          <p id="script-preview" class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap"></p>
        </div>
        <div class="flex items-center justify-between mt-4 text-sm text-gray-400">
          <span>Template: <span class="text-purple-400 capitalize">{template}</span></span>
          <span>Duration: <span class="text-purple-400">{duration}s</span></span>
          <span>Aspect: <span class="text-purple-400">{aspectRatio}</span></span>
        </div>
      </div>

      <!-- Voice Selection Section -->
      <div class="bg-white/5 backdrop-blur-sm rounded-xl border border-white/10 p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-semibold text-white">Choose Your Voice</h2>
          
          <!-- Filter Buttons -->
          <div class="flex gap-2">
            <button id="filter-all" class="voice-filter-btn active" data-filter="all">
              All Voices
            </button>
            <button id="filter-premium" class="voice-filter-btn" data-filter="premium">
              Premium Only
            </button>
          </div>
        </div>

        <!-- Loading State -->
        <div id="voices-loading" class="text-center py-12">
          <div class="animate-spin w-8 h-8 border-2 border-purple-500 border-t-transparent rounded-full mx-auto mb-4"></div>
          <p class="text-gray-400">Loading voices...</p>
        </div>

        <!-- Error State -->
        <div id="voices-error" class="hidden text-center py-12">
          <div class="text-red-400 text-xl mb-4">⚠️</div>
          <p id="error-message" class="text-red-400 mb-4">Failed to load voices</p>
          <button id="retry-voices" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg transition-colors">
            Try Again
          </button>
        </div>

        <!-- Voices Grid -->
        <div id="voices-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
          <!-- Voice cards will be populated here -->
        </div>

        <!-- Continue Section -->
        <div id="continue-section" class="hidden">
          <div class="border-t border-white/10 pt-6">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="bg-green-500/20 text-green-400 p-2 rounded-lg">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-white font-medium">Voice Selected</p>
                  <p id="selected-voice-name" class="text-gray-400 text-sm"></p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <button id="back-to-voices" class="text-gray-400 hover:text-white transition-colors">
                  Change Voice
                </button>
                <button id="generate-audio-btn" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-lg transition-colors">
                  <span id="default-text">Generate Audio</span>
                  <span id="generating-text" class="hidden">
                    <svg class="animate-spin -ml-1 mr-2 h-4 w-4 inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Generating...
                  </span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Audio Preview Modal -->
    <div id="audio-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
      <div class="bg-white/10 backdrop-blur-md rounded-xl border border-white/20 p-6 max-w-md w-full">
        <div class="flex items-center justify-between mb-4">
          <h3 id="modal-voice-name" class="text-lg font-semibold text-white"></h3>
          <button id="close-modal" class="text-gray-400 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        
        <!-- Preview Loading -->
        <div id="preview-loading" class="text-center py-8">
          <div class="animate-spin w-8 h-8 border-2 border-purple-500 border-t-transparent rounded-full mx-auto mb-4"></div>
          <p class="text-gray-300">Generating preview...</p>
        </div>

        <!-- Preview Error -->
        <div id="preview-error" class="hidden text-center py-8">
          <div class="text-red-400 text-xl mb-4">⚠️</div>
          <p class="text-red-400">Failed to generate preview</p>
        </div>
        
        <!-- Audio Player -->
        <div id="audio-player-container" class="hidden">
          <div class="bg-black/20 rounded-lg p-4 mb-4">
            <audio id="preview-audio" controls class="w-full">
              <source type="audio/mpeg">
              Your browser does not support the audio element.
            </audio>
          </div>
          
          <!-- Modal Actions -->
          <div class="flex gap-3">
            <button id="replay-audio" class="flex-1 bg-gray-600 hover:bg-gray-700 text-white py-2 rounded-lg transition-colors">
              Replay
            </button>
            <button id="select-voice-btn" class="flex-1 bg-purple-600 hover:bg-purple-700 text-white py-2 rounded-lg transition-colors">
              Select This Voice
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .voice-filter-btn {
      @apply px-4 py-2 rounded-lg border border-white/20 text-gray-300 hover:text-white hover:border-white/40 transition-all;
    }
    
    .voice-filter-btn.active {
      @apply bg-purple-600 text-white border-purple-600;
    }
    
    .voice-card {
      @apply bg-white/5 backdrop-blur-sm rounded-lg border border-white/10 p-4 hover:bg-white/10 hover:border-purple-500/50 transition-all cursor-pointer relative;
    }
    
    .voice-card.selected {
      @apply bg-purple-600/20 border-purple-500 ring-2 ring-purple-500/50;
    }
    
    .voice-attribute {
      @apply inline-block bg-white/10 text-xs px-2 py-1 rounded-full text-gray-300;
    }
    
    .premium-badge {
      @apply bg-gradient-to-r from-yellow-400 to-orange-500 text-black text-xs px-2 py-1 rounded-full font-medium;
    }

    .preview-button {
      @apply bg-purple-600 hover:bg-purple-700 text-white px-3 py-1 rounded text-sm transition-colors;
    }
  </style>

  <script>
    console.log('🎭 Voice Selection Page Starting...');
    
    // Global variables
    let allVoices = [];
    let selectedVoice = null;
    let currentFilter = 'all';
    let currentPreviewVoice = null;
    
    // Page parameters
    const urlParams = new URLSearchParams(window.location.search);
    const template = urlParams.get('template');
    const duration = urlParams.get('duration');
    const aspectRatio = urlParams.get('aspectRatio');
    const script = urlParams.get('script');
    
    console.log('🎭 Voice Selection initialized with:', { template, duration, aspectRatio, script });
    
    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
      console.log('🎭 DOM loaded, initializing voice selection...');
      initializePage();
    });
    
    function initializePage() {
      console.log('🎭 Initializing page...');
      
      // Set script preview
      if (script) {
        const decodedScript = decodeURIComponent(script);
        document.getElementById('script-preview').textContent = decodedScript;
        console.log('🎭 Script loaded, length:', decodedScript.length);
      } else {
        console.warn('🚨 No script parameter found in URL');
      }
      
      // Try to restore selected voice from session
      try {
        const savedVoice = sessionStorage.getItem('selectedVoice');
        if (savedVoice) {
          selectedVoice = JSON.parse(savedVoice);
          console.log('🎭 Restored selected voice from session:', selectedVoice);
        }
      } catch (e) {
        console.warn('Could not restore from sessionStorage', e);
      }
      
      // Set up event listeners
      setupEventListeners();
      
      // Load voices
      loadVoices();
    }
    
    function setupEventListeners() {
      console.log('🎭 Setting up event listeners...');
      
      // Filter buttons
      document.getElementById('filter-all').addEventListener('click', () => setFilter('all'));
      document.getElementById('filter-premium').addEventListener('click', () => setFilter('premium'));
      
      // Retry button
      document.getElementById('retry-voices').addEventListener('click', loadVoices);
      
      // Continue section
      document.getElementById('back-to-voices').addEventListener('click', () => {
        selectedVoice = null;
        updateContinueSection();
        document.querySelectorAll('.voice-card').forEach(card => card.classList.remove('selected'));
      });
      
      document.getElementById('generate-audio-btn').addEventListener('click', generateAudio);
    }
    
    async function loadVoices() {
      console.log('🎭 Loading voices from API...');
      
      showVoicesLoading();
      
      try {
        const response = await fetch('/api/get-voices', {
          method: 'GET',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        
        console.log('🎭 API Response status:', response.status);
        
        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ error: 'Network error' }));
          throw new Error(errorData.error || `HTTP ${response.status}: ${response.statusText}`);
        }
        
        const data = await response.json();
        console.log('🎭 API Response data:', data);
        
        if (!data.success) {
          throw new Error(data.error || 'Failed to load voices');
        }
        
        if (!data.voices || !Array.isArray(data.voices)) {
          throw new Error('Invalid response format - voices not found');
        }
        
        allVoices = data.voices;
        console.log(`🎭 Successfully loaded ${allVoices.length} voices`);
        
        hideVoicesLoading();
        renderVoices();
        
      } catch (error) {
        console.error('🚨 Error loading voices:', error);
        showVoicesError(error.message);
      }
    }
    
    function showVoicesLoading() {
      document.getElementById('voices-loading').classList.remove('hidden');
      document.getElementById('voices-error').classList.add('hidden');
      document.getElementById('voices-grid').classList.add('hidden');
    }
    
    function hideVoicesLoading() {
      document.getElementById('voices-loading').classList.add('hidden');
    }
    
    function showVoicesError(message) {
      document.getElementById('voices-loading').classList.add('hidden');
      document.getElementById('voices-grid').classList.add('hidden');
      document.getElementById('voices-error').classList.remove('hidden');
      document.getElementById('error-message').textContent = message;
    }
    
    function renderVoices() {
      console.log('🎭 Rendering voices, filter:', currentFilter);
      
      const filteredVoices = filterVoices(allVoices);
      const grid = document.getElementById('voices-grid');
      
      if (filteredVoices.length === 0) {
        grid.innerHTML = '<div class="col-span-full text-center py-8 text-gray-400">No voices found for current filter</div>';
        grid.classList.remove('hidden');
        return;
      }
      
      grid.innerHTML = filteredVoices.map(voice => createVoiceCard(voice)).join('');
      grid.classList.remove('hidden');
      
      // Add click listeners to voice cards
      grid.querySelectorAll('.voice-card').forEach(card => {
        card.addEventListener('click', (e) => {
          // Don't select if clicking preview button
          if (e.target.closest('.preview-button')) return;
          
          const voiceId = card.dataset.voiceId;
          const voiceName = card.dataset.voiceName;
          selectVoice(voiceId, voiceName);
        });
        
        // Highlight previously selected voice if any
        if (selectedVoice && card.dataset.voiceId === selectedVoice.id) {
          card.classList.add('selected');
          updateContinueSection();
          console.log('🎭 Restored UI selection for voice:', selectedVoice.name);
        }
      });
      
      // Add preview button listeners
      grid.querySelectorAll('.preview-button').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const card = e.target.closest('.voice-card');
          const voiceId = card.dataset.voiceId;
          
          try {
            const btn = e.target;
            const originalText = btn.textContent;
            btn.disabled = true;
            btn.innerHTML = `
              <svg class="animate-spin h-4 w-4 mr-2 inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Loading...
            `;
            
            const response = await fetch('/api/preview-voice', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ voiceId })
            });
            
            if (!response.ok) {
              throw new Error('Failed to generate preview');
            }
            
            const data = await response.json();
            
            if (!data.success || !data.audioUrl) {
              throw new Error(data.error || 'Failed to generate preview');
            }
            
            const audio = new Audio(data.audioUrl);
            await audio.play();
            
            btn.disabled = false;
            btn.textContent = originalText;
            
          } catch (error) {
            console.error('🚨 Error previewing voice:', error);
            alert('Failed to preview voice. Please try again.');
            
            btn.disabled = false;
            btn.textContent = 'Preview Voice';
          }
        });
      });
    }
    
    function filterVoices(voices) {
      if (currentFilter === 'premium') {
        return voices.filter(voice => voice.labels?.premium);
      }
      return voices;
    }
    
    function createVoiceCard(voice) {
      const labels = voice.labels || {};
      const isPremium = labels.premium;
      
      return `
        <div class="voice-card" data-voice-id="${voice.voice_id}" data-voice-name="${voice.name}">
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-medium text-white truncate flex-1">${voice.name}</h3>
            ${isPremium ? '<span class="premium-badge ml-2">Premium</span>' : ''}
          </div>
          
          <div class="flex flex-wrap gap-1 mb-3">
            ${labels.gender ? `<span class="voice-attribute">${labels.gender}</span>` : ''}
            ${labels.accent ? `<span class="voice-attribute">${labels.accent}</span>` : ''}
            ${labels.age ? `<span class="voice-attribute">${labels.age}</span>` : ''}
          </div>
          
          <div class="flex items-center justify-between">
            <button class="preview-button">
              Preview Voice
            </button>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
      `;
    }
    
    function setFilter(filter) {
      console.log('🎭 Setting filter to:', filter);
      
      currentFilter = filter;
      
      // Update filter buttons
      document.querySelectorAll('.voice-filter-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      document.getElementById(`filter-${filter}`).classList.add('active');
      
      // Re-render voices
      renderVoices();
    }
    
    function selectVoice(voiceId, voiceName) {
      console.log('🎭 Selecting voice:', { id: voiceId, name: voiceName });
      
      // Store the selected voice
      selectedVoice = { id: voiceId, name: voiceName };
      
      // Save to sessionStorage as backup
      try {
        sessionStorage.setItem('selectedVoice', JSON.stringify(selectedVoice));
      } catch (e) {
        console.warn('Could not save to sessionStorage', e);
      }
      
      // Update UI
      document.querySelectorAll('.voice-card').forEach(card => {
        card.classList.remove('selected');
        if (card.dataset.voiceId === voiceId) {
          card.classList.add('selected');
        }
      });
      
      updateContinueSection();
      
      console.log('🎭 Voice selection complete, stored:', selectedVoice);
    }
    
    function updateContinueSection() {
      const continueSection = document.getElementById('continue-section');
      const selectedVoiceName = document.getElementById('selected-voice-name');
      
      if (selectedVoice) {
        selectedVoiceName.textContent = selectedVoice.name;
        continueSection.classList.remove('hidden');
        console.log('🎭 Voice selected, showing continue section');
      } else {
        continueSection.classList.add('hidden');
        console.log('🎭 No voice selected, hiding continue section');
      }
    }
    
    async function generateAudio() {
      if (!selectedVoice || !script) {
        console.error('🚨 Missing required data for audio generation:', {
          hasVoice: !!selectedVoice,
          voiceId: selectedVoice?.id,
          hasScript: !!script,
          scriptLength: script?.length
        });
        
        // Show more specific error message
        if (!selectedVoice) {
          alert('Please select a voice before generating audio');
        } else if (!script) {
          alert('Script is missing. Please go back to the create page and enter a script');
        } else {
          alert('Script and voice ID are required');
        }
        return;
      }
      
      const decodedScript = decodeURIComponent(script);
      console.log('🎭 Generating audio with:', {
        voiceId: selectedVoice.id,
        scriptLength: decodedScript.length,
        scriptPreview: decodedScript.substring(0, 50) + '...'
      });
      
      const btn = document.getElementById('generate-audio-btn');
      const generatingText = document.getElementById('generating-text');
      const defaultText = document.getElementById('default-text');
      
      btn.disabled = true;
      generatingText.classList.remove('hidden');
      defaultText.classList.add('hidden');
      
      try {
        console.log('🎭 Sending audio generation request with payload:', {
          voiceId: selectedVoice.id,
          scriptLength: decodedScript.length
        });
        
        const response = await fetch('/api/generate-audio', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            script: decodedScript,
            voiceId: selectedVoice.id
          })
        });
        
        console.log('🎭 Generate audio response status:', response.status);
        
        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ error: 'Network error' }));
          throw new Error(errorData.error || `HTTP ${response.status}: ${response.statusText}`);
        }
        
        const data = await response.json();
        
        if (!data.success) {
          throw new Error(data.error || 'Audio generation failed');
        }
        
        console.log('🎭 Audio generated successfully, proceeding to video generation...');
        
        // Proceed to video generation with audio URL
        const videoParams = new URLSearchParams({
          template,
          duration,
          aspectRatio,
          script: encodeURIComponent(script),
          voiceId: selectedVoice.id,
          voiceName: encodeURIComponent(selectedVoice.name),
          audioUrl: encodeURIComponent(data.audioUrl)
        });
        
        window.location.href = `/video-generation?${videoParams.toString()}`;
        
      } catch (error) {
        console.error('🚨 Error generating audio:', error);
        alert(`Failed to generate audio: ${error.message}`);
        
        // Reset button
        btn.disabled = false;
        generatingText.classList.add('hidden');
        defaultText.classList.remove('hidden');
      }
    }
  </script>
</Layout> 