      width: 350px;
      height: 622px;
      border-radius: 24px;
      overflow: hidden;
      position: relative;
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2);
      border: 4px solid #f3f4f6;
      background: #000;
    }

    .video-frame iframe {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 20px;
    }

    .video-overlay-blocker {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: transparent;
      z-index: 10;
      pointer-events: none;
      border-radius: 20px;
      overflow: hidden;
    }

    .video-overlay-blocker::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 80px;
      background: linear-gradient(to bottom, 
        rgba(0,0,0,0.9) 0%, 
        rgba(0,0,0,0.7) 40%,
        rgba(0,0,0,0.3) 70%,
        transparent 100%);
      z-index: 11;
    }

    .video-overlay-blocker::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 60px;
      background: linear-gradient(to top, 
        rgba(0,0,0,0.8) 0%, 
        rgba(0,0,0,0.4) 50%,
        transparent 100%);
      z-index: 11;
    }

    .video-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.1);
      border-radius: 20px;
      opacity: 0;
      transition: opacity 0.3s ease;
      z-index: 12;
      pointer-events: none;
    }

    .video-frame:hover .video-overlay {
      opacity: 1;
    }

    .play-indicator {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border-radius: 50%;
      width: 64px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1e40af;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
      animation: playPulse 2s ease-in-out infinite;
    }

    @keyframes playPulse {
      0%, 100% { transform: scale(1); box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2); }
      50% { transform: scale(1.05); box-shadow: 0 12px 35px rgba(0, 0, 0, 0.3); }
    }

    /* Enhanced Floating Elements */
    .floating-element {
      position: absolute;
      animation: floatAround 6s ease-in-out infinite;
      z-index: 15;
      pointer-events: none;
    }

    .floating-icon {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(15px);
      border-radius: 50%;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
      border: 2px solid rgba(255, 255, 255, 0.3);
    }

    .floating-element-1 {
      top: 20px;
      left: -30px;
      animation-delay: 0s;
    }

    .floating-element-2 {
      top: 50%;
      right: -35px;
      animation-delay: 2s;
    }

    .floating-element-3 {
      bottom: 80px;
      left: -25px;
      animation-delay: 4s;
    }

    @keyframes floatAround {
      0%, 100% { 
        transform: translateY(0px) rotate(0deg);
        opacity: 0.8;
      }
      25% { 
        transform: translateY(-10px) rotate(5deg);
        opacity: 1;
      }
      50% { 
        transform: translateY(-5px) rotate(-5deg);
        opacity: 0.9;
      }
      75% { 
        transform: translateY(-15px) rotate(3deg);
        opacity: 1;
      }
    }

    .floating-element:hover .floating-icon {
      transform: scale(1.1);
      box-shadow: 0 12px 35px rgba(0, 0, 0, 0.25);
    }

    /* Video Carousel Section - Enhanced */
    .carousel-section {
      padding: 6rem 0;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }

    .section-title {
