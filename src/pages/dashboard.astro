declare global {
  interface Window {
    templates: typeof templates;
  }
}
---

<Layout title="Create Amazing Videos with AI">
  <main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Create Amazing Videos with AI</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">Transform your ideas into engaging videos using AI-powered tools. Choose from our templates or create your own custom content.</p>
        
        <!-- Billing Section Button -->
        <div class="mt-6">
          <button 
            id="openBillingBtn"
            class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold rounded-lg hover:from-purple-700 hover:to-blue-700 transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
            Upgrade Your Plan
          </button>
        </div>
      </div>

      <!-- Rest of the dashboard content stays the same -->
      <!-- Duration Selection -->
      <div class="max-w-3xl mx-auto mb-8">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Select Duration</h2>
        <div class="flex gap-4 justify-center flex-wrap">
          {durations.map(({ value, label }) => (
            <button 
              data-duration={value}
              class="duration-btn px-6 py-3 rounded-lg border-2 border-blue-500 text-blue-500 font-medium hover:bg-blue-50 transition-all duration-200 hover:scale-105"
            >
              {label}
            </button>
          ))}
        </div>
      </div>

      <!-- Template Grid -->
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-semibold text-gray-900 mb-8">Choose a Template</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {templates.map(template => (
            <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-all duration-300 hover:scale-105">
              <div class="p-6">
                <div class="text-3xl mb-4">{template.icon}</div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{template.name}</h3>
                <p class="text-gray-600 mb-4">{template.description}</p>
                <button 
                  data-template-id={template.id}
                  data-prompt={template.prompt}
                  onclick={`handleTemplateClick('${template.id}', '${template.prompt}')`}
                  class="generate-btn w-full bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition-all duration-200 font-medium opacity-50 cursor-not-allowed disabled:opacity-50"
                  disabled
                >
                  {template.id === 'manual' ? 'Enter Script Manually' : 'Generate Script'}
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </main>

  <script>
    // Authentication check for dashboard
    window.addEventListener('DOMContentLoaded', async () => {
      try {
        const { supabase } = await import('../lib/supabase.ts');
        
        if (!supabase) {
          window.location.replace('/landing');
          return;
        }
        
        const { data: { session } } = await supabase.auth.getSession();
        
        if (!session) {
          console.log('No session found on dashboard, redirecting to landing...');
          window.location.replace('/landing');
          return;
        }
        
        // Set up auth state listener for real-time changes
        supabase.auth.onAuthStateChange((event, session) => {
          if (event === 'SIGNED_OUT' || !session) {
            window.location.replace('/landing');
          }
        });
      } catch (error) {
        console.error('Dashboard auth check error:', error);
        window.location.replace('/landing');
      }
    });
  </script>
</Layout> 