---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Check authentication - redirect to landing if not authenticated
// Skip check if Supabase client is not initialized (during build)
if (supabase) {
  const cookies = Astro.cookies;
  const accessToken = cookies.get('sb-access-token')?.value;
  const refreshToken = cookies.get('sb-refresh-token')?.value;

  if (!accessToken || !refreshToken) {
    // No tokens found, redirect to landing
    return Astro.redirect('/landing');
  }

  // Verify the session is valid
  try {
    const { data: { user }, error } = await supabase.auth.getUser(accessToken);
    
    if (error || !user) {
      // Invalid session, redirect to landing
      return Astro.redirect('/landing');
    }
  } catch (error) {
    // Any error, redirect to landing
    console.error('Auth verification error:', error);
    return Astro.redirect('/landing');
  }
} else {
  console.warn('Supabase client not initialized during build, skipping server-side auth check');
}

const templates = [
  {
    id: 'custom',
    name: 'Custom Prompt',
    description: 'Create a video from your own custom script or prompt.',
    icon: '💡',
    prompt: 'Create a custom video script based on user input.'
  },
  {
    id: 'manual',
    name: 'Manual Script Input',
    description: 'Enter your own pre-written script directly.',
    icon: '✍️',
    prompt: 'manual-input'
  },
  {
    id: 'random',
    name: 'Random AI Story',
    description: 'Generate a completely unique and engaging story.',
    icon: '🎲',
    prompt: 'Create an engaging and unique story that captures attention from the first second. Make it creative and unexpected.'
  },
  {
    id: 'travel',
    name: 'Travel Destinations',
    description: 'Create beautiful videos about travel destinations and experiences.',
    icon: '✈️',
    prompt: 'Create an engaging travel video script that showcases the beauty and excitement of exploring new destinations.'
  },
  {
    id: 'what-if',
    name: 'What If?',
    description: 'Explore hypothetical scenarios and their fascinating implications.',
    icon: '🤔',
    prompt: 'Create an intriguing what-if scenario that makes viewers think and wonder about possibilities.'
  },
  {
    id: 'scary',
    name: 'Scary Stories',
    description: 'Generate viral scary stories with psychological horror.',
    icon: '👻',
    prompt: 'Create a spine-chilling story that builds psychological tension and ends with an unexpected twist.'
  },
  {
    id: 'bedtime',
    name: 'Bedtime Stories',
    description: 'Soothing and imaginative stories perfect for bedtime.',
    icon: '🌙',
    prompt: 'Create a soothing and imaginative bedtime story that helps listeners relax and dream.'
  },
  {
    id: 'history',
    name: 'Interesting History',
    description: 'Fascinating historical events and little-known stories.',
    icon: '📚',
    prompt: 'Create an engaging historical narrative about a fascinating but lesser-known event or person from history.'
  },
  {
    id: 'urban-legends',
    name: 'Urban Legends',
    description: 'Explore intriguing urban legends and modern myths.',
    icon: '🏙️',
    prompt: 'Create an engaging retelling of an urban legend or modern myth, building intrigue and mystery.'
  },
  {
    id: 'motivational',
    name: 'Motivational',
    description: 'Inspiring stories and motivational content.',
    icon: '💪',
    prompt: 'Create an inspiring and motivational story that energizes and encourages positive action.'
  },
  {
    id: 'fun-facts',
    name: 'Fun Facts',
    description: 'Interesting and surprising facts that captivate viewers.',
    icon: '🎯',
    prompt: 'Create an engaging script about mind-blowing facts that surprise and educate.'
  },
  {
    id: 'jokes',
    name: 'Long Form Jokes',
    description: 'Extended format jokes and humorous stories.',
    icon: '😄',
    prompt: 'Create a clever long-form joke or humorous story with a satisfying punchline.'
  },
  {
    id: 'life-tips',
    name: 'Life Pro Tips',
    description: 'Useful life hacks and practical tips.',
    icon: '💡',
    prompt: 'Create a practical and useful life hack or tip that provides real value.'
  }
];

const durations = [
  { value: '30', label: '30 seconds' },
  { value: '60', label: '60 seconds' },
  { value: '90', label: '90 seconds' }
];

const aspectRatios = [
  { value: '9:16', label: 'Vertical (9:16)', description: 'Best for TikTok, Instagram Reels, YouTube Shorts' },
  { value: '16:9', label: 'Horizontal (16:9)', description: 'Best for YouTube, Desktop viewing' },
  { value: '1:1', label: 'Square (1:1)', description: 'Best for Instagram, Facebook' }
];

declare global {
  interface Window {
    templates: typeof templates;
  }
}
---

<Layout title="Create Amazing Videos with AI">
  <main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-8">
