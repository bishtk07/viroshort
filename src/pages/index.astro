---
import Layout from '../layouts/Layout.astro';

const templates = [
  {
    id: 'custom',
    name: 'Custom Prompt',
    description: 'Create a video from your own custom script or prompt.',
    icon: '💡',
    prompt: 'Create a custom video script based on user input.'
  },
  {
    id: 'manual',
    name: 'Manual Script Input',
    description: 'Enter your own pre-written script directly.',
    icon: '✍️',
    prompt: 'manual-input'
  },
  {
    id: 'random',
    name: 'Random AI Story',
    description: 'Generate a completely unique and engaging story.',
    icon: '🎲',
    prompt: 'Create an engaging and unique story that captures attention from the first second. Make it creative and unexpected.'
  },
  {
    id: 'travel',
    name: 'Travel Destinations',
    description: 'Create beautiful videos about travel destinations and experiences.',
    icon: '✈️',
    prompt: 'Create an engaging travel video script that showcases the beauty and excitement of exploring new destinations.'
  },
  {
    id: 'what-if',
    name: 'What If?',
    description: 'Explore hypothetical scenarios and their fascinating implications.',
    icon: '🤔',
    prompt: 'Create an intriguing what-if scenario that makes viewers think and wonder about possibilities.'
  },
  {
    id: 'scary',
    name: 'Scary Stories',
    description: 'Generate viral scary stories with psychological horror.',
    icon: '👻',
    prompt: 'Create a spine-chilling story that builds psychological tension and ends with an unexpected twist.'
  },
  {
    id: 'bedtime',
    name: 'Bedtime Stories',
    description: 'Soothing and imaginative stories perfect for bedtime.',
    icon: '🌙',
    prompt: 'Create a soothing and imaginative bedtime story that helps listeners relax and dream.'
  },
  {
    id: 'history',
    name: 'Interesting History',
    description: 'Fascinating historical events and little-known stories.',
    icon: '📚',
    prompt: 'Create an engaging historical narrative about a fascinating but lesser-known event or person from history.'
  },
  {
    id: 'urban-legends',
    name: 'Urban Legends',
    description: 'Explore intriguing urban legends and modern myths.',
    icon: '🏙️',
    prompt: 'Create an engaging retelling of an urban legend or modern myth, building intrigue and mystery.'
  },
  {
    id: 'motivational',
    name: 'Motivational',
    description: 'Inspiring stories and motivational content.',
    icon: '💪',
    prompt: 'Create an inspiring and motivational story that energizes and encourages positive action.'
  },
  {
    id: 'fun-facts',
    name: 'Fun Facts',
    description: 'Interesting and surprising facts that captivate viewers.',
    icon: '🎯',
    prompt: 'Create an engaging script about mind-blowing facts that surprise and educate.'
  },
  {
    id: 'jokes',
    name: 'Long Form Jokes',
    description: 'Extended format jokes and humorous stories.',
    icon: '😄',
    prompt: 'Create a clever long-form joke or humorous story with a satisfying punchline.'
  },
  {
    id: 'life-tips',
    name: 'Life Pro Tips',
    description: 'Useful life hacks and practical tips.',
    icon: '💡',
    prompt: 'Create a practical and useful life hack or tip that provides real value.'
  }
];

const durations = [
  { value: '30', label: '30 seconds' },
  { value: '60', label: '60 seconds' },
  { value: '90', label: '90 seconds' }
];

const aspectRatios = [
  { value: '9:16', label: 'Vertical (9:16)', description: 'Best for TikTok, Instagram Reels, YouTube Shorts' },
  { value: '16:9', label: 'Horizontal (16:9)', description: 'Best for YouTube, Desktop viewing' },
  { value: '1:1', label: 'Square (1:1)', description: 'Best for Instagram, Facebook' }
];

declare global {
  interface Window {
    templates: typeof templates;
  }
}
---

<Layout title="Create Amazing Videos with AI">
  <main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Create Amazing Videos with AI</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">Transform your ideas into engaging videos using AI-powered tools. Choose from our templates or create your own custom content.</p>
      </div>

      <!-- Duration Selection -->
      <div class="max-w-3xl mx-auto mb-8">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Select Duration</h2>
        <div class="flex gap-4 justify-center flex-wrap">
          {durations.map(({ value, label }) => (
            <button 
              data-duration={value}
              class="duration-btn px-6 py-3 rounded-lg border-2 border-blue-500 text-blue-500 font-medium hover:bg-blue-50 transition-all duration-200 hover:scale-105"
            >
              {label}
            </button>
          ))}
        </div>
      </div>

      <!-- Aspect Ratio Selection -->
      <div class="max-w-3xl mx-auto mb-8">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Select Aspect Ratio</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {aspectRatios.map(({ value, label, description }) => (
            <button 
              data-aspect-ratio={value}
              class="aspect-ratio-btn p-4 rounded-lg border-2 border-blue-500 text-blue-500 font-medium hover:bg-blue-50 transition-all duration-200 hover:scale-105 text-center"
            >
              <div class="font-semibold">{label}</div>
              <div class="text-sm text-gray-600 mt-1">{description}</div>
            </button>
          ))}
        </div>
      </div>

      <!-- Art Style Selection -->
      <div class="max-w-3xl mx-auto mb-8">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Select Art Style</h2>
        <div class="relative">
          <select id="artStyleSelect" class="w-full p-4 rounded-lg border-2 border-blue-500 text-gray-900 font-medium bg-white appearance-none cursor-pointer focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
            <option value="viroshorts">Viroshorts - Cinematic 8K Ultra HD</option>
            <option value="lego">LEGO - LEGO brick style</option>
            <option value="comic-book">Comic Book - Bold comic style</option>
            <option value="disney-toon">Disney Toon - Classic Disney style</option>
            <option value="studio-chili">Studio Chili - Modern illustration</option>
            <option value="childrens-book">Children's Book - Storybook art</option>
            <option value="photo-realism">Photo Realism - Ultra-realistic photos</option>
            <option value="minecraft">Minecraft - Voxel game style</option>
            <option value="watchmen">Watchmen - Gritty noir comic</option>
            <option value="watercolor">Watercolor - Traditional painting</option>
            <option value="expressionism">Expressionism - Bold emotional art</option>
            <option value="charcoal">Charcoal - Dramatic B&W</option>
            <option value="gtav">GTAV - Modern game graphics</option>
            <option value="anime">Anime - Japanese animation</option>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-700">
            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
              <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Manual Script Input (Initially Hidden) -->
      <div id="manualScriptSection" class="max-w-3xl mx-auto mb-8 hidden">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Enter Your Script</h2>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
          <textarea 
            id="manualScriptInput"
            placeholder="Enter your script here..."
            class="w-full h-32 p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"
          ></textarea>
          <div class="flex justify-between items-center mt-4">
            <span id="wordCount" class="text-sm text-gray-600">0 words</span>
            <button 
              id="useManualScript"
              class="px-6 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed"
              disabled
            >
              Use This Script
            </button>
          </div>
        </div>
      </div>

      <!-- Test Configuration Button (Debug) -->
      <div class="max-w-3xl mx-auto mb-8 text-center">
        <button 
          id="testConfigBtn"
          class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors text-sm"
        >
          Test API Configuration
        </button>
        <div id="configResults" class="mt-2 text-sm text-gray-600"></div>
      </div>

      <!-- Template Grid -->
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-semibold text-gray-900 mb-8">Choose a Template</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {templates.map(template => (
            <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-all duration-300 hover:scale-105">
              <div class="p-6">
                <div class="text-3xl mb-4">{template.icon}</div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{template.name}</h3>
                <p class="text-gray-600 mb-4">{template.description}</p>
                <button 
                  data-template-id={template.id}
                  data-prompt={template.prompt}
                  onclick={`handleTemplateClick('${template.id}', '${template.prompt}')`}
                  class="generate-btn w-full bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition-all duration-200 font-medium opacity-50 cursor-not-allowed disabled:opacity-50"
                  disabled
                >
                  {template.id === 'manual' ? 'Enter Script Manually' : 'Generate Script'}
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Error Message Display -->
      <div id="errorMessage" class="max-w-3xl mx-auto mt-8 hidden">
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Error</h3>
              <div class="mt-2 text-sm text-red-700">
                <p id="errorText"></p>
              </div>
              <div class="mt-4" id="errorActions"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  let selectedDuration = null;
  let selectedAspectRatio = null;
  let selectedStyle = 'viroshorts'; // Default style

  // Duration selection
  document.querySelectorAll('.duration-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.duration-btn').forEach(b => {
        b.classList.remove('bg-blue-500', 'text-white');
        b.classList.add('text-blue-500');
      });
      
      btn.classList.remove('text-blue-500');
      btn.classList.add('bg-blue-500', 'text-white');
      
      selectedDuration = btn.dataset.duration;
      checkEnableGenerate();
    });
  });

  // Aspect ratio selection
  document.querySelectorAll('.aspect-ratio-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.aspect-ratio-btn').forEach(b => {
        b.classList.remove('bg-blue-500', 'text-white');
        b.classList.add('text-blue-500');
      });
      
      btn.classList.remove('text-blue-500');
      btn.classList.add('bg-blue-500', 'text-white');
      
      selectedAspectRatio = btn.dataset.aspectRatio;
      checkEnableGenerate();
    });
  });

  // Art style selection
  const artStyleSelect = document.getElementById('artStyleSelect');
  artStyleSelect.addEventListener('change', (e) => {
    selectedStyle = e.target.value;
    localStorage.setItem('selectedStyle', selectedStyle);
    checkEnableGenerate();
  });

  // Manual script input handling
  const manualScriptInput = document.getElementById('manualScriptInput');
  const wordCountDisplay = document.getElementById('wordCount');
  const useManualScriptBtn = document.getElementById('useManualScript');

  manualScriptInput.addEventListener('input', (e) => {
    const text = e.target.value;
    const wordCount = text.trim() ? text.trim().split(/\s+/).length : 0;
    wordCountDisplay.textContent = `${wordCount} words`;
    
    useManualScriptBtn.disabled = wordCount === 0;
  });

  useManualScriptBtn.addEventListener('click', () => {
    const script = manualScriptInput.value.trim();
    if (script) {
      proceedWithScript(script, 'manual');
    }
  });

  function checkEnableGenerate() {
    const generateButtons = document.querySelectorAll('.generate-btn');
    if (selectedDuration && selectedAspectRatio && selectedStyle) {
      generateButtons.forEach(btn => {
        btn.disabled = false;
        btn.classList.remove('opacity-50', 'cursor-not-allowed');
      });
    } else {
      generateButtons.forEach(btn => {
        btn.disabled = true;
        btn.classList.add('opacity-50', 'cursor-not-allowed');
      });
    }
  }

  function hideError() {
    document.getElementById('errorMessage').classList.add('hidden');
  }

  function showError(message, type = 'error', actions = []) {
    const errorDiv = document.getElementById('errorMessage');
    const errorText = document.getElementById('errorText');
    const errorActions = document.getElementById('errorActions');
    
    errorText.textContent = message;
    
    // Clear previous actions
    errorActions.innerHTML = '';
    
    // Add action buttons if provided
    if (actions.length > 0) {
      const actionButtons = actions.map(action => 
        `<button onclick="${action.handler}" class="mr-2 px-4 py-2 text-sm font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">${action.label}</button>`
      ).join('');
      errorActions.innerHTML = actionButtons;
    }
    
    errorDiv.classList.remove('hidden');
    errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  window.handleTemplateClick = function(templateId, prompt) {
    if (!selectedDuration || !selectedAspectRatio || !selectedStyle) {
      showError('Please select duration, aspect ratio, and art style first');
      return;
    }

    hideError();

    if (templateId === 'manual') {
      // Show manual script input section
      document.getElementById('manualScriptSection').classList.remove('hidden');
      document.getElementById('manualScriptSection').scrollIntoView({ behavior: 'smooth' });
      manualScriptInput.focus();
      return;
    }

    generateScript(templateId, prompt);
  }

  window.generateScript = async function(templateId, prompt) {
    // Show loading state
    const button = document.querySelector(`button[data-template-id="${templateId}"]`);
    if (button) {
      button.disabled = true;
      button.innerHTML = `
        <div class="flex items-center justify-center">
          <svg class="animate-spin h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Generating...
        </div>
      `;
    }

    try {
      console.log('Sending request with:', { 
        prompt, 
        duration: parseInt(selectedDuration),
        template: templateId
      });
      
      const response = await fetch('/api/generate-script', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          prompt: prompt,
          duration: parseInt(selectedDuration),
          template: templateId
        })
      });

      console.log('Response status:', response.status);

      const data = await response.json();
      console.log('Received response:', data);

      if (!response.ok || !data.success) {
        let errorActions = [];
        
        if (data.errorType === 'quota_exceeded') {
          errorActions = [
            {
              label: 'Enter Script Manually',
              handler: 'showManualInput()'
            },
            {
              label: 'Check OpenAI Billing',
              handler: 'window.open("https://platform.openai.com/account/billing", "_blank")'
            }
          ];
        } else if (data.errorType === 'rate_limit') {
          errorActions = [
            {
              label: 'Try Again',
              handler: `generateScript('${templateId}', '${prompt}')`
            },
            {
              label: 'Enter Script Manually',
              handler: 'showManualInput()'
            }
          ];
        }
        
        throw new Error(data.error || 'Failed to generate script');
      }

      if (!data.script) {
        throw new Error('No script content received from API');
      }

      proceedWithScript(data.script, templateId);

    } catch (error) {
      console.error('Error in generateScript:', error);
      showError(error.message, 'error', error.errorActions || []);
    } finally {
      // Reset button state
      if (button) {
        button.disabled = false;
        button.textContent = 'Generate Script';
        checkEnableGenerate();
      }
    }
  }

  function proceedWithScript(script, templateId) {
    // Store generated script and selected parameters
    localStorage.setItem('generatedScript', script);
    localStorage.setItem('selectedStyle', selectedStyle);
    
    console.log('Script stored in localStorage:', script.substring(0, 100) + '...');
    
    // Redirect to voice selection page with parameters
    window.location.href = `/voice-selection?template=${templateId}&duration=${selectedDuration}&aspectRatio=${selectedAspectRatio}&style=${selectedStyle}&script=${encodeURIComponent(script)}`;
  }

  window.showManualInput = function() {
    hideError();
    document.getElementById('manualScriptSection').classList.remove('hidden');
    document.getElementById('manualScriptSection').scrollIntoView({ behavior: 'smooth' });
    manualScriptInput.focus();
  }

  // Test configuration button
  document.getElementById('testConfigBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('testConfigBtn');
    const results = document.getElementById('configResults');
    
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Testing...';
    }
    
    if (results) {
      results.textContent = 'Checking API configuration...';
    }

    try {
      const response = await fetch('/api/test-config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      const data = await response.json();
      
      if (results) {
        if (data.success) {
          results.innerHTML = `
            <div class="text-green-600">
              ✅ OpenAI: ${data.config.hasOpenAI ? 'Configured' : 'Missing'} (${data.config.openAILength} chars)<br>
              ✅ ElevenLabs: ${data.config.hasElevenLabs ? 'Configured' : 'Missing'} (${data.config.elevenLabsLength} chars)
            </div>
          `;
        } else {
          results.innerHTML = `<div class="text-red-600">❌ Error: ${data.error}</div>`;
        }
      }
    } catch (error) {
      if (results) {
        results.innerHTML = `<div class="text-red-600">❌ Failed to test: ${error.message}</div>`;
      }
    }

    if (btn) {
      btn.disabled = false;
      btn.textContent = 'Test API Configuration';
    }
  });
</script>

<style>
  .duration-btn.selected {
    @apply bg-blue-500 text-white;
  }

  .generate-btn:disabled {
    @apply opacity-50 cursor-not-allowed;
  }

  /* Smooth animations */
  * {
    transition-property: transform, opacity, background-color, border-color, color;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 200ms;
  }

  /* Focus styles for accessibility */
  button:focus,
  select:focus,
  textarea:focus {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }
</style> 