                  <div class="text-sm text-green-600 mb-4" id="starterSavings">Save $8/month</div>
                  <button 
                    class="w-full bg-purple-600 text-white py-3 rounded-lg font-medium hover:bg-purple-700 transition-colors upgrade-btn"
                    data-plan="starter"
                  >
                    Upgrade to Starter
                  </button>
                </div>
                <ul class="mt-6 space-y-3 text-sm text-gray-600">
