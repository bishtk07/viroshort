                </ul>
              </div>

              <!-- Hardcore Plan -->
              <div class="border border-gray-200 rounded-xl p-6 hover:border-purple-300 transition-colors">
                <div class="text-center">
                  <h3 class="text-xl font-semibold text-gray-900 mb-2">Hardcore</h3>
