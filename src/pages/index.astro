            <button 
              data-duration={value}
              class="duration-btn px-6 py-3 rounded-lg border-2 border-blue-500 text-blue-500 font-medium hover:bg-blue-50 transition-all duration-200 hover:scale-105"
            >
              {label}
            </button>
          ))}
        </div>
      </div>

      <!-- Aspect Ratio Selection -->
      <div class="max-w-3xl mx-auto mb-8">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Select Aspect Ratio</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {aspectRatios.map(({ value, label, description }) => (
            <button 
              data-aspect-ratio={value}
              class="aspect-ratio-btn p-4 rounded-lg border-2 border-blue-500 text-blue-500 font-medium hover:bg-blue-50 transition-all duration-200 hover:scale-105 text-center"
