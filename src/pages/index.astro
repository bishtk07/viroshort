        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Select Art Style</h2>
        <div class="relative">
          <select id="artStyleSelect" class="w-full p-4 rounded-lg border-2 border-blue-500 text-gray-900 font-medium bg-white appearance-none cursor-pointer focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
            <option value="viroshorts">Viroshorts - Cinematic 8K Ultra HD</option>
            <option value="lego">LEGO - LEGO brick style</option>
            <option value="comic-book">Comic Book - Bold comic style</option>
            <option value="disney-toon">Disney Toon - Classic Disney style</option>
            <option value="studio-chili">Studio Chili - Modern illustration</option>
            <option value="childrens-book">Children's Book - Storybook art</option>
            <option value="photo-realism">Photo Realism - Ultra-realistic photos</option>
            <option value="minecraft">Minecraft - Voxel game style</option>
            <option value="watchmen">Watchmen - Gritty noir comic</option>
            <option value="watercolor">Watercolor - Traditional painting</option>
            <option value="expressionism">Expressionism - Bold emotional art</option>
            <option value="charcoal">Charcoal - Dramatic B&W</option>
            <option value="gtav">GTAV - Modern game graphics</option>
            <option value="anime">Anime - Japanese animation</option>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-700">
            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
              <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Manual Script Input (Initially Hidden) -->
      <div id="manualScriptSection" class="max-w-3xl mx-auto mb-8 hidden">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">Enter Your Script</h2>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
          <textarea 
            id="manualScriptInput"
            placeholder="Enter your script here..."
            class="w-full h-32 p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"
          ></textarea>
          <div class="flex justify-between items-center mt-4">
            <span id="wordCount" class="text-sm text-gray-600">0 words</span>
            <button 
              id="useManualScript"
              class="px-6 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed"
              disabled
            >
              Use This Script
            </button>
          </div>
        </div>
      </div>

      <!-- Test Configuration Button (Debug) -->
      <div class="max-w-3xl mx-auto mb-8 text-center">
        <button 
          id="testConfigBtn"
          class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors text-sm"
        >
          Test API Configuration
        </button>
        <div id="configResults" class="mt-2 text-sm text-gray-600"></div>
      </div>

      <!-- Template Grid -->
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-semibold text-gray-900 mb-8">Choose a Template</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {templates.map(template => (
            <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-all duration-300 hover:scale-105">
              <div class="p-6">
                <div class="text-3xl mb-4">{template.icon}</div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{template.name}</h3>
                <p class="text-gray-600 mb-4">{template.description}</p>
                <button 
                  data-template-id={template.id}
                  data-prompt={template.prompt}
                  onclick={`handleTemplateClick('${template.id}', '${template.prompt}')`}
                  class="generate-btn w-full bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition-all duration-200 font-medium opacity-50 cursor-not-allowed disabled:opacity-50"
                  disabled
                >
                  {template.id === 'manual' ? 'Enter Script Manually' : 'Generate Script'}
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Error Message Display -->
      <div id="errorMessage" class="max-w-3xl mx-auto mt-8 hidden">
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Error</h3>
              <div class="mt-2 text-sm text-red-700">
                <p id="errorText"></p>
              </div>
              <div class="mt-4" id="errorActions"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Recovery Section -->
      <section id="quick-recovery" class="glass-card" style="display: none;">
        <h2>⚡ Quick Recovery Options</h2>
        <p>API temporarily unavailable? Continue with these options:</p>
        
        <div class="recovery-options">
          <div class="sample-scripts">
            <h3>📝 Sample Scripts</h3>
            <div class="script-buttons">
              <button onclick="useSampleScript('tech')" class="sample-btn">
                <i class="fas fa-laptop"></i>
                Tech Review
              </button>
              <button onclick="useSampleScript('tutorial')" class="sample-btn">
                <i class="fas fa-graduation-cap"></i>
                Tutorial
              </button>
              <button onclick="useSampleScript('story')" class="sample-btn">
                <i class="fas fa-book"></i>
                Story
              </button>
              <button onclick="useSampleScript('product')" class="sample-btn">
                <i class="fas fa-shopping-cart"></i>
                Product Demo
              </button>
            </div>
          </div>
          
          <div class="manual-entry">
            <h3>✍️ Manual Entry</h3>
            <p>Write your own script in the text area below and continue with customization.</p>
            <button onclick="hideQuickRecovery(); document.getElementById('customization').scrollIntoView({behavior: 'smooth'})" class="recovery-action-btn">
              <i class="fas fa-edit"></i>
              Write My Own Script
            </button>
          </div>
        </div>
      </section>

      <!-- Script Customization Section -->
    </div>
  </main>
</Layout>

<script>
  // ✅ Import browser compatibility utilities
  import { safeStorage, detectBrowserFeatures, initBrowserCompat } from '../utils/browserCompat.js';
  
  // ✅ Double-check authentication on client side
  window.addEventListener('DOMContentLoaded', async () => {
    try {
      const { supabase } = await import('../lib/supabase.ts');
      const { data: { session } } = await supabase.auth.getSession();
      
      if (!session) {
        console.log('No session found, redirecting to landing...');
        window.location.replace('/landing');
        return;
      }
      
      // Also set up auth state listener for real-time changes
      supabase.auth.onAuthStateChange((event, session) => {
        if (event === 'SIGNED_OUT' || !session) {
          window.location.replace('/landing');
        }
      });
    } catch (error) {
      console.error('Client auth check error:', error);
      window.location.replace('/landing');
    }
  });
  
  // Initialize browser compatibility
  const browserFeatures = initBrowserCompat();
  
  console.log('Browser features detected:', browserFeatures);
  
  let selectedTemplate = null;
  let selectedStyle = null;
  let selectedDuration = null;
  let selectedAspectRatio = null;

  // ✅ Use safe storage instead of direct localStorage
  function saveSelections() {
    if (selectedTemplate && selectedStyle && selectedDuration && selectedAspectRatio) {
      const selections = {
        template: selectedTemplate,
        style: selectedStyle,
        duration: selectedDuration,
        aspectRatio: selectedAspectRatio,
        timestamp: Date.now()
      };
      
      safeStorage.setItem('userSelections', JSON.stringify(selections));
      safeStorage.setItem('finalStyle', selectedStyle);
      
      console.log('Selections saved:', selections);
    }
  }

  // ✅ Restore previous selections using safe storage
  function restoreSelections() {
    try {
      const saved = safeStorage.getItem('userSelections');
      if (saved) {
        const selections = JSON.parse(saved);
        
        // Only restore if selections are recent (within 1 hour)
        if (Date.now() - selections.timestamp < 3600000) {
          selectedTemplate = selections.template;
          selectedStyle = selections.style;
          selectedDuration = selections.duration;
          selectedAspectRatio = selections.aspectRatio;
          
          // Update UI to reflect restored selections
          updateUIFromSelections();
        }
      }
    } catch (e) {
      console.warn('Failed to restore selections:', e);
    }
  }

  function updateUIFromSelections() {
    // Update template selection
    if (selectedTemplate) {
      const templateCard = document.querySelector(`[data-template="${selectedTemplate}"]`);
      if (templateCard) {
        templateCard.classList.add('ring-2', 'ring-blue-500');
      }
    }
    
    // Update style selection
    if (selectedStyle) {
      const styleButton = document.querySelector(`[data-style="${selectedStyle}"]`);
      if (styleButton) {
        styleButton.classList.add('ring-2', 'ring-blue-500');
      }
    }
    
    // Update duration selection
    if (selectedDuration) {
      const durationButton = document.querySelector(`[data-duration="${selectedDuration}"]`);
      if (durationButton) {
        durationButton.classList.add('bg-blue-500', 'text-white');
      }
    }
    
    // Update aspect ratio selection
    if (selectedAspectRatio) {
      const ratioButton = document.querySelector(`[data-ratio="${selectedAspectRatio}"]`);
      if (ratioButton) {
        ratioButton.classList.add('bg-blue-500', 'text-white');
      }
    }
    
    updateContinueButton();
  }

  function updateContinueButton() {
    const continueBtn = document.getElementById('continueBtn');
    if (continueBtn) {
      if (selectedTemplate && selectedStyle && selectedDuration && selectedAspectRatio) {
        continueBtn.disabled = false;
        continueBtn.classList.remove('bg-gray-400', 'cursor-not-allowed');
        continueBtn.classList.add('bg-blue-500', 'hover:bg-blue-600');
      } else {
        continueBtn.disabled = true;
        continueBtn.classList.add('bg-gray-400', 'cursor-not-allowed');
        continueBtn.classList.remove('bg-blue-500', 'hover:bg-blue-600');
      }
    }
  }

  // Initialize page
  document.addEventListener('DOMContentLoaded', () => {
    // Restore previous selections
    restoreSelections();
    
    // Set up event listeners for selections
    setupEventListeners();
  });

  function setupEventListeners() {
    // Template selection
    document.querySelectorAll('[data-template]').forEach(card => {
      card.addEventListener('click', (e) => {
        selectedTemplate = e.currentTarget.dataset.template;
        
        // Update UI
        document.querySelectorAll('[data-template]').forEach(c => 
          c.classList.remove('ring-2', 'ring-blue-500')
        );
        e.currentTarget.classList.add('ring-2', 'ring-blue-500');
        
        saveSelections();
        updateContinueButton();
      });
    });
    
    // Style selection
    document.querySelectorAll('[data-style]').forEach(button => {
      button.addEventListener('click', (e) => {
        selectedStyle = e.currentTarget.dataset.style;
        
        // Update UI
        document.querySelectorAll('[data-style]').forEach(b => 
          b.classList.remove('ring-2', 'ring-blue-500')
        );
        e.currentTarget.classList.add('ring-2', 'ring-blue-500');
        
        saveSelections();
        updateContinueButton();
      });
    });
    
    // Duration selection
    document.querySelectorAll('[data-duration]').forEach(button => {
      button.addEventListener('click', (e) => {
        selectedDuration = e.currentTarget.dataset.duration;
        
        // Update UI
        document.querySelectorAll('[data-duration]').forEach(b => {
          b.classList.remove('bg-blue-500', 'text-white');
          b.classList.add('bg-gray-200', 'text-gray-700');
        });
        e.currentTarget.classList.add('bg-blue-500', 'text-white');
        e.currentTarget.classList.remove('bg-gray-200', 'text-gray-700');
        
        saveSelections();
        updateContinueButton();
      });
    });
    
    // Aspect ratio selection
    document.querySelectorAll('[data-ratio]').forEach(button => {
      button.addEventListener('click', (e) => {
        selectedAspectRatio = e.currentTarget.dataset.ratio;
        
        // Update UI
        document.querySelectorAll('[data-ratio]').forEach(b => {
          b.classList.remove('bg-blue-500', 'text-white');
          b.classList.add('bg-gray-200', 'text-gray-700');
        });
        e.currentTarget.classList.add('bg-blue-500', 'text-white');
        e.currentTarget.classList.remove('bg-gray-200', 'text-gray-700');
        
        saveSelections();
        updateContinueButton();
      });
    });
    
    // Continue button
    const continueBtn = document.getElementById('continueBtn');
    if (continueBtn) {
      continueBtn.addEventListener('click', () => {
        if (selectedTemplate && selectedStyle && selectedDuration && selectedAspectRatio) {
          const params = new URLSearchParams({
            template: selectedTemplate,
            style: selectedStyle,
            duration: selectedDuration,
            aspectRatio: selectedAspectRatio
          });
          
          window.location.href = `/create?${params.toString()}`;
        }
      });
    }
  }

  // Duration selection
  document.querySelectorAll('.duration-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.duration-btn').forEach(b => {
        b.classList.remove('bg-blue-500', 'text-white');
        b.classList.add('text-blue-500');
      });
      
      btn.classList.remove('text-blue-500');
      btn.classList.add('bg-blue-500', 'text-white');
      
      selectedDuration = btn.dataset.duration;
      checkEnableGenerate();
    });
  });

  // Aspect ratio selection
  document.querySelectorAll('.aspect-ratio-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.aspect-ratio-btn').forEach(b => {
        b.classList.remove('bg-blue-500', 'text-white');
        b.classList.add('text-blue-500');
      });
      
      btn.classList.remove('text-blue-500');
      btn.classList.add('bg-blue-500', 'text-white');
      
      selectedAspectRatio = btn.dataset.aspectRatio;
      checkEnableGenerate();
    });
  });

  // Art style selection
  const artStyleSelect = document.getElementById('artStyleSelect');
  artStyleSelect.addEventListener('change', (e) => {
    selectedStyle = e.target.value;
    localStorage.setItem('selectedStyle', selectedStyle);
    checkEnableGenerate();
  });

  // Manual script input handling
  const manualScriptInput = document.getElementById('manualScriptInput');
  const wordCountDisplay = document.getElementById('wordCount');
  const useManualScriptBtn = document.getElementById('useManualScript');

  manualScriptInput.addEventListener('input', (e) => {
    const text = e.target.value;
    const wordCount = text.trim() ? text.trim().split(/\s+/).length : 0;
    wordCountDisplay.textContent = `${wordCount} words`;
    
    useManualScriptBtn.disabled = wordCount === 0;
  });

  useManualScriptBtn.addEventListener('click', () => {
    const script = manualScriptInput.value.trim();
    if (script) {
      proceedWithScript(script, 'manual');
    }
  });

  function checkEnableGenerate() {
    const generateButtons = document.querySelectorAll('.generate-btn');
    if (selectedDuration && selectedAspectRatio && selectedStyle) {
      generateButtons.forEach(btn => {
        btn.disabled = false;
        btn.classList.remove('opacity-50', 'cursor-not-allowed');
      });
    } else {
      generateButtons.forEach(btn => {
        btn.disabled = true;
        btn.classList.add('opacity-50', 'cursor-not-allowed');
      });
    }
  }

  function hideError() {
    document.getElementById('errorMessage').classList.add('hidden');
  }

  function showError(message, type = 'error', actions = []) {
    const errorDiv = document.getElementById('errorMessage');
    const errorText = document.getElementById('errorText');
    const errorActions = document.getElementById('errorActions');
    
    errorText.textContent = message;
    
    // Clear previous actions
    errorActions.innerHTML = '';
    
    // Add action buttons if provided
    if (actions.length > 0) {
      const actionButtons = actions.map(action => 
        `<button onclick="${action.handler}" class="mr-2 px-4 py-2 text-sm font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">${action.label}</button>`
      ).join('');
      errorActions.innerHTML = actionButtons;
    }
    
    errorDiv.classList.remove('hidden');
    errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  window.handleTemplateClick = function(templateId, prompt) {
    if (!selectedDuration || !selectedAspectRatio || !selectedStyle) {
      showError('Please select duration, aspect ratio, and art style first');
      return;
    }

    hideError();

    if (templateId === 'manual') {
      // Show manual script input section
      document.getElementById('manualScriptSection').classList.remove('hidden');
      document.getElementById('manualScriptSection').scrollIntoView({ behavior: 'smooth' });
      manualScriptInput.focus();
      return;
    }

    generateScript(templateId, prompt);
  }

  window.generateScript = async function(templateId, prompt) {
    // Show loading state
    const button = document.querySelector(`button[data-template-id="${templateId}"]`);
    if (button) {
      button.disabled = true;
      button.innerHTML = `
        <div class="flex items-center justify-center">
          <svg class="animate-spin h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Generating...
        </div>
      `;
    }

    try {
      console.log('Sending request with:', { 
        prompt, 
        duration: parseInt(selectedDuration),
        template: templateId
      });
      
      const response = await fetch('/api/generate-script', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          prompt: prompt,
          duration: parseInt(selectedDuration),
          template: templateId
        })
      });

      console.log('Response status:', response.status);

      const data = await response.json();
      console.log('Received response:', data);

      if (!response.ok || !data.success) {
        // Handle quota exceeded specifically
        if (data.errorType === 'quota_exceeded') {
          showQuotaExceededModal(templateId, prompt);
          return;
        } else if (data.errorType === 'rate_limit') {
          showRateLimitModal(templateId, prompt);
          return;
        }
        
        throw new Error(data.error || 'Failed to generate script');
      }

      if (!data.script) {
        throw new Error('No script content received from API');
      }

      proceedWithScript(data.script, templateId);

    } catch (error) {
      console.error('Error in generateScript:', error);
      // Show manual input as primary option for faster workflow
      showErrorWithManualOption(error.message, templateId, prompt);
    } finally {
      // Reset button state
      if (button) {
        button.disabled = false;
        button.textContent = 'Generate Script';
        checkEnableGenerate();
      }
    }
  }

  // New function to handle quota exceeded with fast alternatives
  function showQuotaExceededModal(templateId, prompt) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
      <div class="bg-white p-6 rounded-lg max-w-md mx-4">
        <h3 class="text-lg font-semibold mb-4 text-red-600">⚠️ OpenAI Quota Exceeded</h3>
        <p class="text-gray-600 mb-6">Your OpenAI API quota has been exceeded. Choose a fast alternative:</p>
        <div class="space-y-3">
          <button onclick="useManualScript()" class="w-full bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors">
            ✏️ Enter Script Manually (Fastest)
          </button>
          <button onclick="useSampleScript('${templateId}')" class="w-full bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg transition-colors">
            📄 Use Sample Script (Instant)
          </button>
          <button onclick="window.open('https://platform.openai.com/account/billing', '_blank')" class="w-full bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg transition-colors">
            💳 Add OpenAI Credits
          </button>
          <button onclick="closeModal()" class="w-full bg-gray-300 hover:bg-gray-400 text-gray-700 px-4 py-2 rounded-lg transition-colors">
            Cancel
          </button>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    
    window.closeModal = () => {
      document.body.removeChild(modal);
    };
  }

  // Fast sample scripts for instant testing
  const SAMPLE_SCRIPTS = {
    scary: "The old house creaked as Sarah stepped inside. Each floorboard groaned under her weight, echoing through empty rooms. A door slammed upstairs. But Sarah lived alone. She climbed the stairs, heart pounding. The master bedroom door stood open, revealing fresh muddy footprints leading to her bed. A note lay on her pillow: 'Thanks for letting me stay while you were away.' Sarah had never left.",
    motivational: "Every morning, you wake up with 86,400 seconds in your account. You can't save them for tomorrow. You can't borrow from yesterday. The question isn't whether you have time – it's what you'll do with the time you have. Today, someone will overcome their biggest fear. Someone will start their dream business. Someone will say 'I love you' for the first time. Why not you? The only difference between dreamers and achievers is action. Your moment is now.",
    bedtime: "In a faraway meadow where flowers sing lullabies, there lived a little bunny named Luna. Every night, she would hop from cloud to cloud, sprinkling dream dust on sleeping children. Tonight, she noticed one child tossing and turning. Luna gently landed on the windowsill and hummed a soft melody about peaceful forests and gentle streams. As the child's breathing slowed, Luna smiled. Another sweet dream delivered. Now it's time for you to close your eyes and let Luna visit you too.",
    travel: "Picture this: You're standing on a cliff in Santorini, watching the sun melt into the Aegean Sea. The white-washed buildings glow golden in the evening light. A gentle breeze carries the scent of jasmine and sea salt. This isn't just a vacation – it's a moment that changes you. Travel isn't about checking destinations off a list. It's about collecting moments that expand your soul. Every journey teaches you something new about the world, and more importantly, about yourself.",
    'what-if': "What if gravity worked in reverse for just one hour every day? Imagine waking up, checking your watch, and suddenly feeling your feet lift off the ground. Cars would need ceiling seatbelts. Birds would struggle to fly downward. Rain would fall upward, creating reverse storms. Children would play on playground equipment attached to the ground with chains. And somewhere, a romantic couple would share their first kiss while floating near the ceiling, surrounded by floating flower petals.",
    history: "In 1969, a janitor at NASA named Jack was cleaning offices when he met President Kennedy. Kennedy asked what he was doing. Jack replied, 'I'm helping put a man on the moon, Mr. President.' This wasn't just a clever answer – it was profound truth. Every person at NASA, from astronauts to janitors, understood they were part of something bigger. Success isn't just about individual brilliance. It's about ordinary people doing extraordinary things when they believe in a shared mission.",
    jokes: "A man walks into a library and asks for books on paranoia. The librarian whispers, 'They're right behind you!' He spins around frantically. Nothing there. 'Very funny,' he says. The librarian leans closer: 'No, seriously, the paranoia section is behind you.' He turns again and sees the shelves labeled 'Psychology - Paranoia.' Feeling foolish, he checks out three books. At home, he opens the first one. Page one reads: 'If you're reading this, someone is watching you.' He slams it shut, looks around his empty apartment, then slowly peeks out the window. His neighbor waves cheerfully from across the street.",
    'fun-facts': "Your brain uses the same amount of power as a 20-watt light bulb, yet it's more complex than any computer ever built. Here's what's amazing: right now, 86 billion neurons are firing in your head, creating 100 trillion connections. That's more connections than there are stars in the Milky Way. And here's the kicker – scientists estimate we only use about 10% of our brain's capacity. Imagine what we could accomplish if we unlocked just a little bit more. Your brain is literally the most sophisticated machine in the known universe, and it's sitting right between your ears.",
    'urban-legends': "They say if you drive alone on Route 117 at midnight, you'll see her in your rearview mirror. Emily Patterson, a young woman who died in a car crash in 1987. Drivers report seeing a figure in a white dress sitting in their backseat, always just visible in the mirror's reflection. She never speaks, just points ahead to the exact spot where her accident occurred. Some say she's trying to warn others. Others believe she's searching for her lost wedding ring. But here's what the locals don't tell tourists: Emily Patterson never existed. The real question is – who's been appearing in those cars for 30 years?",
    'life-tips': "Here's a life hack that will save you hours every week: the two-minute rule. If a task takes less than two minutes, do it immediately. Reply to that text. File that document. Wash that dish. Put those clothes away. Most people spend more time thinking about these small tasks than actually doing them. The mental energy wasted on remembering tiny to-dos is exhausting. By handling them instantly, you free your mind for bigger things. Your future self will thank you for not leaving a trail of tiny tasks in your wake.",
    custom: "Every great story starts with a single moment of courage. The moment someone decides to step outside their comfort zone and chase something bigger than themselves. Today could be that moment for you. What if the life you've always dreamed of is just one brave decision away? Stop waiting for permission. Stop waiting for the perfect moment. Stop waiting for fear to disappear. Fear never leaves – courage means moving forward anyway. Your story is being written right now. Make it worth reading.",
    random: "In a world where colors had personalities, blue was always melancholy, red was perpetually angry, and yellow couldn't stop giggling. But green was different – green was the philosopher of the color spectrum. One day, green noticed that whenever colors mixed, they created something entirely new. Orange brought joy and energy. Purple radiated wisdom and mystery. Green realized the most beautiful moments happened not when colors stood alone, but when they blended together. Sometimes the most magical things in life happen when different elements unite to create something extraordinary."
  };

  window.useSampleScript = function(templateId) {
    const script = SAMPLE_SCRIPTS[templateId] || SAMPLE_SCRIPTS.custom;
    proceedWithScript(script, templateId);
    closeModal();
  };

  window.useManualScript = function() {
    closeModal();
    showManualInput();
  };

  function showErrorWithManualOption(errorMessage, templateId, prompt) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
      <div class="bg-white p-6 rounded-lg max-w-md mx-4">
        <h3 class="text-lg font-semibold mb-4 text-red-600">Script Generation Failed</h3>
        <p class="text-gray-600 mb-6">${errorMessage}</p>
        <div class="space-y-3">
          <button onclick="useManualScript()" class="w-full bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors">
            ✏️ Enter Script Manually (Fastest)
          </button>
          <button onclick="useSampleScript('${templateId}')" class="w-full bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg transition-colors">
            📄 Use Sample Script (Instant)
          </button>
          <button onclick="retryGeneration('${templateId}', '${prompt}')" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg transition-colors">
            🔄 Try Again
          </button>
          <button onclick="closeModal()" class="w-full bg-gray-300 hover:bg-gray-400 text-gray-700 px-4 py-2 rounded-lg transition-colors">
            Cancel
          </button>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
  }

  window.retryGeneration = function(templateId, prompt) {
    closeModal();
    generateScript(templateId, prompt);
  };

  function proceedWithScript(script, templateId) {
    // Store generated script and selected parameters
    localStorage.setItem('generatedScript', script);
    localStorage.setItem('selectedStyle', selectedStyle);
    
    console.log('Script stored in localStorage:', script.substring(0, 100) + '...');
    
    // Redirect to voice selection page with parameters
    window.location.href = `/voice-selection?template=${templateId}&duration=${selectedDuration}&aspectRatio=${selectedAspectRatio}&style=${selectedStyle}&script=${encodeURIComponent(script)}`;
  }

  window.showManualInput = function() {
    hideError();
    document.getElementById('manualScriptSection').classList.remove('hidden');
    document.getElementById('manualScriptSection').scrollIntoView({ behavior: 'smooth' });
    manualScriptInput.focus();
  }

  // Test configuration button
  document.getElementById('testConfigBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('testConfigBtn');
    const results = document.getElementById('configResults');
    
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Testing...';
    }
    
    if (results) {
      results.textContent = 'Checking API configuration...';
    }

    try {
      const response = await fetch('/api/test-config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      const data = await response.json();
      
      if (results) {
        if (data.success) {
          results.innerHTML = `
            <div class="text-green-600">
              ✅ OpenAI: ${data.config.hasOpenAI ? 'Configured' : 'Missing'} (${data.config.openAILength} chars)<br>
              ✅ ElevenLabs: ${data.config.hasElevenLabs ? 'Configured' : 'Missing'} (${data.config.elevenLabsLength} chars)
            </div>
          `;
        } else {
          results.innerHTML = `<div class="text-red-600">❌ Error: ${data.error}</div>`;
        }
      }
    } catch (error) {
      if (results) {
        results.innerHTML = `<div class="text-red-600">❌ Failed to test: ${error.message}</div>`;
      }
    }

    if (btn) {
      btn.disabled = false;
      btn.textContent = 'Test API Configuration';
    }
  });

  // Add quick recovery functions
  function showQuickRecovery() {
    const recoverySection = document.getElementById('quick-recovery');
    if (recoverySection) {
      recoverySection.style.display = 'block';
      recoverySection.scrollIntoView({ behavior: 'smooth' });
    }
  }

  function hideQuickRecovery() {
    const recoverySection = document.getElementById('quick-recovery');
    if (recoverySection) {
      recoverySection.style.display = 'none';
    }
  }

  function useSampleScript(template) {
    const script = SAMPLE_SCRIPTS[template];
    if (script) {
      const scriptTextarea = document.getElementById('script');
      if (scriptTextarea) {
        scriptTextarea.value = script;
        hideQuickRecovery();
        // Scroll to next section
        document.getElementById('customization')?.scrollIntoView({ behavior: 'smooth' });
      }
    }
  }

  window.useSampleScript = useSampleScript;
  window.showQuickRecovery = showQuickRecovery;
  window.hideQuickRecovery = hideQuickRecovery;

  // Billing Modal Functionality
  let currentBillingPeriod = 'monthly';
  let paddleInitialized = false;

  // Initialize Paddle when billing modal opens
  function initializePaddle() {
    if (!paddleInitialized && window.Paddle) {
      try {
        // Use production environment and token from environment variable
        window.Paddle.Environment.set('production');
        
        // Get the client token from the environment
        const clientToken = 'PUBLIC_PADDLE_CLIENT_TOKEN' in window 
          ? window.PUBLIC_PADDLE_CLIENT_TOKEN 
          : import.meta.env.PUBLIC_PADDLE_CLIENT_TOKEN;
        
        if (!clientToken) {
          throw new Error('Paddle client token not found in environment variables');
        }
        
        // Then initialize with token and event callback
        window.Paddle.Initialize({
          token: clientToken,
          eventCallback: function(data) {
            console.log('Paddle event:', data);
            
            if (data.name === 'checkout.completed') {
              // Redirect to success page with plan information
              const plan = data.data?.custom_data?.plan || 'unknown';
              const period = data.data?.custom_data?.period || 'monthly';
              window.location.href = `/success?plan=${plan}&period=${period}`;
            } else if (data.name === 'checkout.closed') {
              console.log('Checkout was closed');
            } else if (data.name === 'checkout.error') {
              console.error('Checkout error:', data.error);
              alert('There was an error processing your payment. Please try again.');
            }
          }
        });
        paddleInitialized = true;
        console.log('✅ Paddle initialized successfully');
      } catch (error) {
        console.error('❌ Error initializing Paddle:', error);
        paddleInitialized = false;
        throw error;
      }
    }
  }

  // Plan prices - Updated with actual Paddle price IDs from your system
  const planPrices = {
    starter: {
      monthly: { price: 19, savings: 'Save $8/month', priceId: 'pri_01jy2at6gfgcdcxt4dq94jb50z' },
      weekly: { price: 8, savings: 'Save $3/week', priceId: 'pri_01jy2at8bv9vr8fxq49kq4y3j6' }
    },
    daily: {
      monthly: { price: 39, savings: 'Save $21/month', priceId: 'pri_01jy2atgsxxgm8wnhgdqhed9mq' },
      weekly: { price: 15, savings: 'Save $9/week', priceId: 'pri_01jy2atkp7mwc19kz6ybyjtxkc' }
    },
    hardcore: {
      monthly: { price: 69, savings: 'Save $43/month', priceId: 'pri_01jy2atpsyh60aa8ahb1kmqym3' },
      weekly: { price: 26, savings: 'Save $17/week', priceId: 'pri_01jy2atqzv79317fs6bz3qacvn' }
    }
  };

  // Update pricing display
  function updatePricing() {
    const period = currentBillingPeriod;
    const periodLabel = period === 'monthly' ? '/month' : '/week';
    
    // Update starter plan
    document.getElementById('starterPrice').textContent = '$' + planPrices.starter[period].price;
    document.getElementById('starterSavings').textContent = planPrices.starter[period].savings;
    document.querySelector('#starterPrice').nextElementSibling.textContent = periodLabel;
    
    // Update daily plan
    document.getElementById('dailyPrice').textContent = '$' + planPrices.daily[period].price;
    document.getElementById('dailySavings').textContent = planPrices.daily[period].savings;
    document.querySelector('#dailyPrice').nextElementSibling.textContent = periodLabel;
    
    // Update hardcore plan
    document.getElementById('hardcorePrice').textContent = '$' + planPrices.hardcore[period].price;
    document.getElementById('hardcoreSavings').textContent = planPrices.hardcore[period].savings;
    document.querySelector('#hardcorePrice').nextElementSibling.textContent = periodLabel;
  }

  // Open billing modal
  document.getElementById('openBillingBtn')?.addEventListener('click', () => {
    const modal = document.getElementById('billingModal');
    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      
      // Initialize Paddle when modal opens
      initializePaddle();
    }
  });

  // Close billing modal
  document.getElementById('closeBillingBtn')?.addEventListener('click', () => {
    const modal = document.getElementById('billingModal');
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }
  });

  // Close modal when clicking outside
  document.getElementById('billingModal')?.addEventListener('click', (e) => {
    if (e.target.id === 'billingModal') {
      const modal = document.getElementById('billingModal');
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = 'auto';
      }
    }
  });

  // Billing period toggle
  document.getElementById('monthlyToggle')?.addEventListener('click', () => {
    currentBillingPeriod = 'monthly';
    document.getElementById('monthlyToggle').className = 'px-6 py-2 rounded-md bg-white text-gray-900 font-medium shadow-sm';
    document.getElementById('weeklyToggle').className = 'px-6 py-2 rounded-md text-gray-600 font-medium';
    updatePricing();
  });

  document.getElementById('weeklyToggle')?.addEventListener('click', () => {
    currentBillingPeriod = 'weekly';
    document.getElementById('weeklyToggle').className = 'px-6 py-2 rounded-md bg-white text-gray-900 font-medium shadow-sm';
    document.getElementById('monthlyToggle').className = 'px-6 py-2 rounded-md text-gray-600 font-medium';
    updatePricing();
  });

  // Handle upgrade button clicks
  document.querySelectorAll('.upgrade-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const plan = e.target.dataset.plan;
      const priceId = planPrices[plan][currentBillingPeriod].priceId;
      
      console.log('Upgrading to plan:', plan, 'with price ID:', priceId);
      
      // Check if Paddle is available and initialized
      if (!window.Paddle) {
        console.error('Paddle SDK not loaded');
        alert('Payment system is still loading. Please wait a moment and try again.');
        return;
      }
      
      if (!paddleInitialized) {
        console.log('Initializing Paddle...');
        initializePaddle();
        
        // Wait a moment for initialization
        setTimeout(() => {
          if (paddleInitialized) {
            openCheckout(e.target, plan, priceId);
          } else {
            alert('Payment system is initializing. Please try again in a moment.');
          }
        }, 1000);
      } else {
        openCheckout(e.target, plan, priceId);
      }
    });
  });

  // Separate function to handle checkout opening
  function openCheckout(button, plan, priceId) {
    try {
      // Show loading state
      button.disabled = true;
      button.textContent = 'Loading...';
      
      // Open Paddle checkout
      window.Paddle.Checkout.open({
        items: [{ priceId: priceId, quantity: 1 }],
        settings: {
          displayMode: 'overlay',
          theme: 'light',
          locale: 'en'
        },
        customData: {
          plan: plan,
          period: currentBillingPeriod
        }
      });
      
      // Reset button state after a short delay
      setTimeout(() => {
        button.disabled = false;
        button.textContent = `Upgrade to ${plan.charAt(0).toUpperCase() + plan.slice(1)}`;
      }, 2000);
    } catch (error) {
      console.error('Checkout error:', error);
      button.disabled = false;
      button.textContent = `Upgrade to ${plan.charAt(0).toUpperCase() + plan.slice(1)}`;
      alert('There was an error opening the checkout. Please try again.');
    }
  }

  // Initialize pricing on page load
  updatePricing();
</script>

