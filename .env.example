# ViroShort - Environment Variables Template
# Copy this file to .env and fill in your API keys

# =================================
# 🤖 OPENAI API (Script Generation)
# =================================
# Get your key from: https://platform.openai.com/api-keys
# Used for: Script generation, enhancement, and segmentation
OPENAI_API_KEY=your_openai_api_key_here

# =================================
# 🎨 REPLICATE API (Image Generation)
# =================================
# Get your token from: https://replicate.com/account/api-tokens
# Used for: AI image generation with FLUX models
REPLICATE_API_TOKEN=your_replicate_token_here

# =================================
# 🎙️ FISH AUDIO API (Voice Synthesis)
# =================================
# Get your key from: https://fish.audio/go-api/
# Used for: Natural voice generation and TTS
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here

# =================================
# 📝 INSTRUCTIONS
# =================================
# 1. Sign up for OpenAI: https://platform.openai.com
# 2. Sign up for Replicate: https://replicate.com
# 3. Sign up for Fish Audio: https://fish.audio
# 4. Copy this file to .env
# 5. Replace the placeholder values with your actual API keys
# 6. Never commit your .env file to Git (it's already in .gitignore)

# =================================
# 🚀 DEPLOYMENT NOTES
# =================================
# For Cloudflare Pages deployment:
# - Add these same 3 variables in your Cloudflare Pages dashboard
# - Go to: Settings → Environment variables
# - Add each variable with your actual values