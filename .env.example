# ViroShort - Environment Variables Template
# Copy this file to .env and fill in your API keys

# =================================
# 🎨 REPLICATE API (Image Generation)
# =================================
# Get your token from: https://replicate.com/account/api-tokens
# Used for: AI image generation with FLUX models
REPLICATE_API_TOKEN=your_replicate_token_here

# =================================
# 🎙️ ELEVENLABS API (Voice Synthesis)
# =================================
# Get your key from: https://elevenlabs.io/app/speech-synthesis
# Used for: Natural voice generation and TTS
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# =================================
# 📝 INSTRUCTIONS
# =================================
# 1. Sign up for Replicate: https://replicate.com
# 2. Sign up for ElevenLabs: https://elevenlabs.io
# 3. Copy this file to .env
# 4. Replace the placeholder values with your actual API keys
# 5. Never commit your .env file to Git (it's already in .gitignore)

# =================================
# 🚀 DEPLOYMENT NOTES
# =================================
# For Cloudflare Pages deployment:
# - Add these same variables in your Cloudflare Pages dashboard
# - Go to: Settings → Environment variables
# - Add each variable with your actual values