# ViroShort - Environment Variables Template
# Copy this file to .env and fill in your API keys

# =================================
# 🗄️ SUPABASE (Database)
# =================================
# Get your keys from: https://supabase.com/dashboard/project/[your-project]/settings/api
# Used for: User data, billing records, and authentication
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =================================
# 💳 PADDLE (Payments)
# =================================
# Get your keys from: https://vendors.paddle.com/authentication-v2
# Used for: Subscription payments and billing management
# Format should be: live_xxxxxxxxxxxxxxxxxxxxxxxxx (32+ characters after live_)
# or test_xxxxxxxxxxxxxxxxxxxxxxxxx for sandbox
PUBLIC_PADDLE_CLIENT_TOKEN=live_your_paddle_client_token_here
PADDLE_API_KEY=your_paddle_api_key_here
PUBLIC_PADDLE_ENVIRONMENT=production
PUBLIC_PADDLE_SELLER_ID=your_seller_id_here

# =================================
# 🤖 OPENAI API (Script Generation)
# =================================
# Get your key from: https://platform.openai.com/account/api-keys
# Used for: Script generation, enhancement, and segmentation
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# =================================
# 🎨 REPLICATE API (Image Generation)
# =================================
# Get your token from: https://replicate.com/account/api-tokens
# Used for: AI image generation with FLUX models
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# =================================
# 🎙️ FISH AUDIO API (Voice Synthesis)
# =================================
# Get your key from: https://fish.audio/
# Used for: Natural voice generation and TTS
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here

# =================================
# 🎙️ ELEVEN LABS API (Voice Synthesis)
# =================================
# Get your API key from: https://elevenlabs.io/
ELEVEN_LABS_API_KEY=sk_your_elevenlabs_api_key_here

# =================================
# 📝 INSTRUCTIONS
# =================================
# 1. Sign up for Supabase: https://supabase.com
# 2. Sign up for Paddle: https://vendors.paddle.com
# 3. Sign up for OpenAI: https://platform.openai.com
# 4. Sign up for Replicate: https://replicate.com
# 5. Sign up for Fish Audio: https://fish.audio
# 6. Copy this file to .env
# 7. Replace the placeholder values with your actual API keys
# 8. Never commit your .env file to Git (it's already in .gitignore)

# =================================
# 🚀 DEPLOYMENT NOTES
# =================================
# For Cloudflare Pages deployment:
# - Add these same variables in your Cloudflare Pages dashboard
# - Go to: Settings → Environment variables
# - Add each variable with your actual values

# =================================
# 🎙️ RANDI API (Voice Synthesis)
# =================================
# Get your API key from: https://randi.ai/
RANDI_API_KEY=your_randi_api_key_here

# =================================
# �� NODE ENVIRONMENT
# =================================
# Get your environment from: https://nodejs.org/api/process.html#processenv
NODE_ENV=development

# =================================
# 🎙️ MUX VIDEO API (Video Management)
# =================================
# Get your credentials from: https://dashboard.mux.com/settings/access-tokens
# Create a new access token with Video Read and Write permissions
MUX_TOKEN_ID=your_mux_token_id_here
MUX_TOKEN_SECRET=your_mux_token_secret_here